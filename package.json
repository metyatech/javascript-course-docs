{
  "name": "@metyatech/javascript-course-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Course content repository for the JavaScript course.",
  "scripts": {
    "verify": "npm run lint && npm run format:check",
    "lint": "markdownlint-cli2 \"**/*.md\" \"**/*.mdx\" \"!node_modules/**\" \"!AGENTS.md\" \"!agent-rules-private/**\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.3"
  }
}
